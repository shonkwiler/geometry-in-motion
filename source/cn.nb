Cell[TextData[{
 "To get the final GIF under 10 MB, I used ",
 ButtonBox["Gifsicle",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.lcdf.org/gifsicle/"], None},
  ButtonNote->"https://www.lcdf.org/gifsicle/"],
 ", specifically the following command: "
}], "Text",
 CellChangeTimes->{{3.991238389055794*^9, 3.9912384480428753`*^9}, {
  3.9912385010511007`*^9, 
  3.991238501052061*^9}},ExpressionUUID->"6bac405f-19aa-4a95-9096-\
49d7dca2f77a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"gifsicle", " ", "-", 
   RowBox[{
    RowBox[{"O3", " ", "--"}], 
    RowBox[{"lossy", " ", "--"}], "gamma"}]}], "=", 
  RowBox[{
   RowBox[{"1", " ", 
    RowBox[{"jacobi", ".", "gif"}]}], " ", ">", " ", 
   RowBox[{"jacobir", ".", "gif"}]}]}]], "Code",
 InitializationCell->False,
