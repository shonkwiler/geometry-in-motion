  3.990551243551846*^9}},ExpressionUUID->"801633ca-b6a7-4c52-9003-\
73a1d42df48b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Export", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"NotebookDirectory", "[", "]"}], "<>", "\"\<jacobi.gif\>\""}], ",",
     "jacobi", ",", 
    RowBox[{"\"\<AnimationRepetitions\>\"", "->", "Infinity"}], ",", 
    RowBox[{"\"\<DisplayDurations\>\"", "->", 
     RowBox[{"1", "/", "50"}]}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.9811294264905252`*^9, 3.981129452901763*^9}, {
  3.981129593807571*^9, 3.981129597323359*^9}, {3.990722530910884*^9, 
