   3.902413542412259*^9, 3.902413583308059*^9}, {3.902413636182444*^9, 
   3.9024136601349783`*^9}, {3.902413758550194*^9, 3.9024137893587227`*^9}, {
   3.9338526412901163`*^9, 3.93385264465231*^9}, {3.934642984386739*^9, 
   3.934643056666295*^9}, {3.934643330821686*^9, 3.934643331585654*^9}, 
