     RasterInterpolation->"High"],
    BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSize->{430.80000000000007`, Automatic},
   ImageSizeRaw->{960., 503.},
   PlotRange->{{0, 960.}, {0, 503.}}]], "Input",ExpressionUUID->
  "09050708-2717-48a9-be11-2fbf790c749c"],
 "\n\nFor this parameter ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "0.8"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "98cdf958-ee5c-44cf-a77d-d8b5a4265828"],
 ", we can compute ",
 Cell[BoxData[
  FormBox[
   RowBox[{"K", "(", "m", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e870efc6-3a22-497b-a65c-46084f6c68ef"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"K", "(", 
    RowBox[{"1", "-", "m"}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f578648e-6049-450b-8197-29ad0f94c8e6"],
 " as follows:"
}], "Text",
 CellChangeTimes->{{3.990719725008276*^9, 3.990719774534285*^9}, {
  3.9907198062141247`*^9, 3.990719861795701*^9}, {3.990719900703843*^9, 
  3.990719931176736*^9}},ExpressionUUID->"8f8b733c-59ec-4942-93b7-\
5cf42b307951"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EllipticK", "[", "0.8", "]"}]], "Input",
 CellChangeTimes->{{3.990719737929117*^9, 3.990719740853302*^9}},
 CellLabel->
  "In[104]:=",ExpressionUUID->"f15b88cc-724a-4c66-ba34-0a40bab0eeec"],

Cell[BoxData["2.257205326820854`"], "Output",
 CellChangeTimes->{3.990719741401527*^9},
 CellLabel->
  "Out[104]=",ExpressionUUID->"e0a1289e-65fc-4209-ab8e-d4daf87f8c81"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EllipticK", "[", 
  RowBox[{"1", "-", "0.8"}], "]"}]], "Input",
 CellChangeTimes->{{3.990719934713525*^9, 3.990719939300167*^9}},
 CellLabel->
  "In[105]:=",ExpressionUUID->"e83931ac-09ec-485f-8b7e-87f948f7d160"],

Cell[BoxData["1.6596235986105279`"], "Output",
 CellChangeTimes->{3.990719939672782*^9},
 CellLabel->
  "Out[105]=",ExpressionUUID->"359714fc-5f8c-44b7-a60d-c14bb619571c"]
}, Open  ]],

Cell[TextData[{
 "So we expect to see a (simple) zero of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"cn", "(", 
    RowBox[{"\[CenterDot]", 
     RowBox[{"|", "0.8"}]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dd4c9e4e-3809-4918-8e71-d1e9b4dd235c"],
 " at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[TildeTilde]", "2.257"}], TraditionalForm]],ExpressionUUID->
  "46e1e7a8-75ab-401d-81d6-51fb6cd9a412"],
 " and a (simple) pole at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[TildeTilde]", 
    RowBox[{"1.659", "\[ImaginaryI]"}]}], TraditionalForm]],ExpressionUUID->
  "3eadf503-33fc-4bee-a1c5-7ca0a7051d2a"],
 ", which is indeed what we see in the plot above."
}], "Text",
 CellChangeTimes->{{3.99071994463063*^9, 3.990720030472535*^9}, {
  3.991308113511766*^9, 
  3.9913081209105873`*^9}},ExpressionUUID->"e757c9d9-da3a-4a51-8a23-\
b1f03e5d1a41"],

Cell[TextData[{
 "Now, the idea is that we\[CloseCurlyQuote]re going to get an animation by \
plotting the family ",
 Cell[BoxData[
  FormBox[
   RowBox[{"cn", "(", 
    RowBox[{"\[CenterDot]", 
     RowBox[{"|", 
      SubscriptBox["m", "t"]}]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "982b0039-3c6c-46f9-a74f-a89faa072973"],
 " of Jacobi functions, where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "t"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0e56165a-d7fb-4196-a585-e85bfa612044"],
 " is the family of parameters corresponding to our family ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[CenterDot]", "\[CapitalLambda]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b2c109b5-0673-408d-a5bf-5eec14f3bad7"],
 " of lattices. In principle, since we know the periods of cn and we know the \
lattice ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[CenterDot]", "\[CapitalLambda]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1256b809-fba2-4b35-9da6-30976257d076"],
 ", we could try to solve for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "t"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c9bb3bd9-5275-4d11-a0c2-1b19871dea90"],
 ". I don\[CloseCurlyQuote]t doubt that some cleverer person than I could \
figure this out, but I spent a very long time trying and failing to figure \
this out due to the facts that: (i) ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d84da637-71aa-4bd5-868a-b1c3135f8c54"],
 " has a branch cut discontinuity running from 1 to \[Infinity] and (ii) I\
\[CloseCurlyQuote]m representing ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[CenterDot]", "\[CapitalLambda]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7a49dbdd-745d-41b0-8032-2c17357af85d"],
 " by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"t", "\[CenterDot]", 
     SubscriptBox[
      OverscriptBox["u", "\[RightVector]"], "1"]}], "=", 
    RowBox[{"(", GridBox[{
       {
        RowBox[{
         SuperscriptBox["\[ExponentialE]", "t"], "\[Phi]"}]},
       {
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"-", "t"}]]}
      }], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "21e7ad46-01d9-4853-9f5a-ddea96919c3c"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"t", "\[CenterDot]", 
     SubscriptBox[
      OverscriptBox["u", "\[RightVector]"], "2"]}], "=", 
    RowBox[{"(", GridBox[{
       {
        SuperscriptBox["\[ExponentialE]", "t"]},
       {
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"-", "t"}]]}], "\[Phi]"}]}
      }], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7ac2c350-6a26-4a6e-9a77-c1b6e69903fb"],
 ", which span an increasingly long and pointy parallelogram."
}], "Text",
 CellChangeTimes->{{3.99072004832883*^9, 3.990720058819811*^9}, {
  3.990720098964945*^9, 3.990720216933515*^9}, {3.990720923581345*^9, 
  3.9907212192886543`*^9}},ExpressionUUID->"481949fe-d8a9-443c-a863-\
676a55eda5ef"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Animate", "[", 
  RowBox[{
   RowBox[{"Graphics", "[", 
    RowBox[{
     RowBox[{"Parallelogram", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            SuperscriptBox["E", "t"], "GoldenRatio"}], ",", 
           SuperscriptBox["E", 
            RowBox[{"-", "t"}]]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           SuperscriptBox["E", "t"], ",", 
           RowBox[{
            RowBox[{"-", 
             SuperscriptBox["E", 
              RowBox[{"-", "t"}]]}], "GoldenRatio"}]}], "}"}]}], "}"}]}], 
      "]"}], ",", 
     RowBox[{"PlotRange", "->", "5"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", 
     RowBox[{"Log", "[", 
      RowBox[{"1", "+", "GoldenRatio"}], "]"}]}], "}"}], ",", 
   RowBox[{"SaveDefinitions", "->", "True"}], ",", 
   RowBox[{"AnimationRunning", "->", "False"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.990721248255711*^9, 3.990721338043622*^9}, 
   3.9907213690791073`*^9},
 CellLabel->
  "In[117]:=",ExpressionUUID->"0885f8d1-6a26-4110-b892-41c2b26bc836"],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`t$$ = 0., Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{
      Hold[$CellContext`t$$], 0, 
      Log[1 + GoldenRatio], ControlType -> Animator}}, Typeset`size$$ = {
    360., {177.134033203125, 182.865966796875}}, Typeset`update$$ = 0, 
    Typeset`initDone$$, Typeset`skipInitDone$$ = True, 
    Typeset`keyframeActionsQ$$ = False, Typeset`keyframeList$$ = {}}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, "Variables" :> {$CellContext`t$$ = 0}, 
      "ControllerVariables" :> {}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$, Typeset`keyframeActionsQ$$, 
        Typeset`keyframeList$$}, "Body" :> Graphics[
        Parallelogram[{0, 
         0}, {{E^$CellContext`t$$ GoldenRatio, E^(-$CellContext`t$$)}, {
          E^$CellContext`t$$, (-E^(-$CellContext`t$$)) GoldenRatio}}], 
        PlotRange -> 5], "Specifications" :> {{$CellContext`t$$, 0, 
         Log[1 + GoldenRatio], AnimationRunning -> False, 
         AppearanceElements -> {
          "ProgressSlider", "PlayPauseButton", "FasterSlowerButtons", 
           "DirectionButton"}}}, 
      "Options" :> {
       ControlType -> Animator, AppearanceElements -> None, DefaultBaseStyle -> 
        "Animate", DefaultLabelStyle -> "AnimateLabel", SynchronousUpdating -> 
        True, ShrinkingDelay -> 10.}, "DefaultOptions" :> {}],
     ImageSizeCache->{409.1, {216.634033203125, 222.365966796875}},
     SingleEvaluation->True],
    Deinitialization:>None,
    DynamicModuleValues:>{},
    SynchronousInitialization->True,
    UndoTrackedVariables:>{Typeset`show$$, Typeset`bookmarkMode$$},
    UnsavedVariables:>{Typeset`initDone$$},
    UntrackedVariables:>{Typeset`size$$}], "Animate",
   Deployed->True,
   StripOnInput->False],
  Manipulate`InterpretManipulate[1]]], "Output",
 CellChangeTimes->{{3.990721314425508*^9, 3.9907213387109528`*^9}, 
   3.990721370745661*^9},
 CellLabel->
  "Out[117]=",ExpressionUUID->"5f829ea2-b113-4eda-b9d7-282fb94cfbb7"]
}, Open  ]],

Cell[TextData[{
 "So instead I\[CloseCurlyQuote]m going to represent cn in terms of the \
Weierstrass ",
 Cell[BoxData[
  FormBox["\[WeierstrassP]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1c10bb08-5db9-474c-9165-a0ecafc0d4e0"],
 "-function. In general, an even elliptic function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "7f672000-96e8-400a-adaa-62727aca46ac"],
 " with zeros at ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", 
     SubscriptBox["z", "1"]}], ",", "\[Ellipsis]", ",", 
    RowBox[{"\[PlusMinus]", 
     SubscriptBox["z", "n"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2d599359-f25d-45fb-9ce4-499c541e5014"],
 " and poles at ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", 
     SubscriptBox["p", "1"]}], ",", "\[Ellipsis]", ",", 
    RowBox[{"\[PlusMinus]", 
     SubscriptBox["p", "n"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5ac8e598-f587-44e6-97a7-b7f76faef486"],
 " can be represented as\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "z", ")"}], " ", "=", 
    RowBox[{"a", " ", 
     RowBox[{
      SubsuperscriptBox["\[Product]", 
       RowBox[{"i", "=", "1"}], "n"], 
      FractionBox[
       RowBox[{
        RowBox[{"\[WeierstrassP]", "(", "z", ")"}], "-", 
        RowBox[{"\[WeierstrassP]", "(", 
         SubscriptBox["z", "i"], ")"}]}], 
       RowBox[{
        RowBox[{"\[WeierstrassP]", "(", "z", ")"}], "-", 
        RowBox[{"\[WeierstrassP]", "(", 
         SubscriptBox["p", "i"], ")"}]}]], " "}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6297c400-f711-434c-9da7-4c4681213057"],
 ",\n\t\nwhere ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0c6cddd7-c032-407c-a7aa-3df777d79fae"],
 " is some fixed constant (see, for example, \[Section]8.10 in Lawden\
\[CloseCurlyQuote]s ",
 StyleBox[ButtonBox["Elliptic Functions and Applications",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-1-4757-3980-0"], None},
  ButtonNote->"https://doi.org/10.1007/978-1-4757-3980-0"],
  FontSlant->"Italic"],
 "). Since cn is even, we can use this representation. We know from the \
construction of cn that it should have zeros at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", 
    FractionBox[
     SubscriptBox["\[Omega]", "1"], "4"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5d06dbf8-b697-40b8-b335-0f0c90b886af"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", 
    RowBox[{"(", 
     RowBox[{
      FractionBox[
       RowBox[{"3", 
        SubscriptBox["\[Omega]", "1"]}], "4"], "+", 
      FractionBox[
       SubscriptBox["\[Omega]", "2"], "2"]}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7374c658-98b2-41a6-9f03-0544c0af184e"],
 " and poles at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", 
    FractionBox[
     SubscriptBox["\[Omega]", "2"], "4"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "131f907f-6633-494e-b1a0-3b1093b562e2"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", 
    RowBox[{"(", 
     RowBox[{
      FractionBox[
       RowBox[{"3", 
        SubscriptBox["\[Omega]", "2"]}], "4"], "+", 
      FractionBox[
       SubscriptBox["\[Omega]", "1"], "2"]}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ff70355f-bbd0-4400-9aa1-0b6348aea971"],
 ", so we can just plug these into the above representation to get an \
alternative formula for cn."
}], "Text",
 CellChangeTimes->{{3.990878466673088*^9, 3.990878499755231*^9}, {
  3.991224903441455*^9, 3.9912249578502197`*^9}, {3.991225119720006*^9, 
  3.9912251937906427`*^9}, {3.991225236188589*^9, 3.991225310067605*^9}, {
  3.9912254028993187`*^9, 3.9912254456050797`*^9}, {3.9912255340059223`*^9, 
  3.9912255636666203`*^9}, {3.9912258530609207`*^9, 3.9912259377560062`*^9}, {
  3.991226812494677*^9, 
  3.991226893740045*^9}},ExpressionUUID->"3ddce721-526a-424d-adf8-\
6d878d18c9b4"],

Cell[TextData[{
 "That said, while the lattice has period ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", "0"], "=", 
    RowBox[{"ln", "(", 
     RowBox[{"1", "+", "\[Phi]"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0a6cd411-3bb1-4a51-9c79-da24724da905"],
 ", the zeros and poles don\[CloseCurlyQuote]t come back to themselves in a \
single period (in the below, zeros are shown in red and poles in blue):"
}], "Text",
 CellChangeTimes->{{3.991235123732727*^9, 3.991235134131152*^9}, {
  3.991235164340901*^9, 3.991235209956442*^9}, {3.991240242683154*^9, 
