Cell[TextData[{
 "In particular, if ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "eec85012-9bbe-4f37-85c0-b4e10395a8fe"],
 " has columns ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["u", "\[RightVector]"], "1"], TraditionalForm]],
  ExpressionUUID->"20c77396-e338-4023-8f00-0aadf0d6dd96"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["u", "\[RightVector]"], "2"], TraditionalForm]],
  ExpressionUUID->"71a2426f-945f-44c4-a418-5b85a3802834"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{"(", GridBox[{
       {"2", "1"},
       {"1", "1"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "167d50fa-8f6d-48b5-9d00-476f51402909"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"diag", "(", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        SubscriptBox["t", "0"]], ",", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         SubscriptBox["t", "0"]}]]}], ")"}], "U"}], "=", 
    RowBox[{"U", " ", "B"}]}], TraditionalForm]],ExpressionUUID->
  "9330666e-a68b-47d8-8e9d-64eaf0d63d13"],
 " or, equivalently,"
}], "Text",
 CellChangeTimes->{{3.991234873726454*^9, 3.991234937198992*^9}, {
  3.991234970083136*^9, 
  3.991235028554039*^9}},ExpressionUUID->"97383669-3953-42bc-af33-\
2b04448f319a"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"diag", "(", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        SubscriptBox["t", "0"]], ",", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         SubscriptBox["t", "0"]}]]}], ")"}], 
     SubscriptBox[
      OverscriptBox["u", "\[RightVector]"], "1"]}], "=", 
    RowBox[{
     RowBox[{"2", 
      SubscriptBox[
       OverscriptBox["u", "\[RightVector]"], "1"]}], "+", 
     SubscriptBox[
      OverscriptBox["u", "\[RightVector]"], "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5e8d75a8-fa08-42f9-982b-fd4c4932a414"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"diag", "(", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        SubscriptBox["t", "0"]], ",", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         SubscriptBox["t", "0"]}]]}], ")"}], 
     SubscriptBox[
      OverscriptBox["u", "\[RightVector]"], "2"]}], "=", 
    RowBox[{
     SubscriptBox[
      OverscriptBox["u", "\[RightVector]"], "1"], "+", 
     SubscriptBox[
      OverscriptBox["u", "\[RightVector]"], "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "deca91f6-7dd0-4718-860a-3553a9c2c8c2"],
 "."
}], "Text",
 CellChangeTimes->{{3.991235032062923*^9, 
  3.991235093961039*^9}},ExpressionUUID->"a18c6f91-85ce-441c-8fdb-\
6f1646616634"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Jacobi elliptic function", "Section",
 CellChangeTimes->{{3.990718823756052*^9, 
  3.990718828566348*^9}},ExpressionUUID->"13e2f1d9-3d06-4a32-a0b3-\
110aec045e60"],

Cell[TextData[{
 "In general, ",
 StyleBox[ButtonBox["elliptic functions",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Elliptic_function"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Elliptic_function"],
  FontSlant->"Italic"],
 " are doubly-periodic meromorphic functions on the complex plane ",
 Cell[BoxData[
  FormBox["\[DoubleStruckCapitalC]", TraditionalForm]],ExpressionUUID->
  "fa0f6cf2-c814-494d-9f7a-dd2d78dd88de"],
 ". The Jacobi elliptic functions are a basic family of elliptic functions of \
the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{"pq", "(", 
    RowBox[{"u", "|", "m"}], ")"}], TraditionalForm]],ExpressionUUID->
  "a80ca5cf-3547-4d86-a387-2ea86d37f0ea"],
 ", where p and q are any of the letters c, s, n, or d, ",
 Cell[BoxData[
  FormBox["u", TraditionalForm]],ExpressionUUID->
  "b7c89b9b-de36-48ea-9db8-c7c78fcbbd1a"],
 " is the argument, and ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "cee87105-ecf2-41fc-b99b-74bb699c50a0"],
 " is a parameter which implicitly specifies the lattice (or, equivalently, a \
given lattice specifies the parameter ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "f2ca3ef4-3986-41ba-a256-cc5a8195bc8d"],
 "): for any integers ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],ExpressionUUID->
  "576e604b-0c41-4d81-8a98-cbc1f070f1fb"],
 " and ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]],ExpressionUUID->
  "a5a94af2-617c-4cc1-b0ac-75119de16fd9"],
 ", \n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"pq", "(", 
     RowBox[{
      RowBox[{"u", "+", 
       RowBox[{"2", "\[Alpha]", " ", 
        RowBox[{"K", "(", "m", ")"}]}], "+", 
       RowBox[{"2", "\[ImaginaryI]", " ", "\[Beta]", " ", 
        RowBox[{"K", "(", 
         RowBox[{"1", "-", "m"}], ")"}]}]}], "|", "m"}], ")"}], " ", "=", " ", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "\[Gamma]"], 
     RowBox[{"pq", "(", 
      RowBox[{"u", "|", "m"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "c2e0a449-e48f-4e8e-b775-21c965eefae1"],
 ", \n\nwhere ",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]],ExpressionUUID->
  "3116887a-7dd2-4cd3-b43d-da7290304ff2"],
 " is determined by p, q, ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],ExpressionUUID->
  "8ed52723-34ca-4ccd-9b6d-9217e6ec7e42"],
 ", and ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]],ExpressionUUID->
  "c17a7ac6-3c58-4aa3-aa49-6bb5e9ab2599"],
 " and ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]],ExpressionUUID->
  "dfdc668c-3dd5-474b-9ac5-7bf2dceb583e"],
 " is the ",
 ButtonBox["elliptic integral",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Elliptic_integral"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Elliptic_integral"],
 " of the first kind. For example, for the cn function we have ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"\[Alpha]", "+", "\[Beta]"}]}], TraditionalForm]],ExpressionUUID->
  "31758b0e-61c5-4323-8ebb-0320ebbc7f5f"],
 ", so that \n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cn", "(", 
     RowBox[{
      RowBox[{"u", "+", 
       RowBox[{"4", "\[Alpha]", " ", 
        RowBox[{"K", "(", "m", ")"}]}]}], " ", "|", "m"}], ")"}], " ", "=", 
    " ", 
    RowBox[{"cn", "(", 
     RowBox[{"u", "|", "m"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "25c60b39-c1ea-4fb6-80d2-6b1f89a5d5c9"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cn", "(", 
     RowBox[{
      RowBox[{"u", "+", 
       RowBox[{"4", "\[ImaginaryI]", " ", "\[Beta]", " ", 
        RowBox[{"K", "(", 
         RowBox[{"1", "-", "m"}], ")"}]}]}], "|", "m"}], ")"}], "=", 
    RowBox[{"cn", "(", 
     RowBox[{"u", "|", "m"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "48e7be12-327c-4aef-9528-83a22b82f433"],
 ",\n\t\nand we see that the periods of cn are ",
 Cell[BoxData[
  FormBox[
   RowBox[{"4", 
    RowBox[{"K", "(", "m", ")"}]}], TraditionalForm]],ExpressionUUID->
  "c888099e-9ae7-4ac5-9e12-9602a23068d2"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"4", "\[ImaginaryI]", " ", 
    RowBox[{"K", "(", 
     RowBox[{"1", "-", "m"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "7d521fc1-722a-4728-8939-43bc8ade261e"],
 ".\n\nFor example, ",
 Cell[BoxData[
  FormBox["cn", TraditionalForm]],ExpressionUUID->
  "0af936ac-7e83-47bc-9143-8ad1407cc473"],
 " is implemented in Mathematica as ",
 StyleBox["JacobiCN", "Input"],
 ":"
}], "Text",
 CellChangeTimes->{{3.990718833271577*^9, 3.990718874920525*^9}, {
  3.990718914700758*^9, 3.990719048447465*^9}, {3.990719088811758*^9, 
  3.990719123544873*^9}, {3.9907192749051743`*^9, 3.990719411332096*^9}, {
  3.990719467583622*^9, 
  3.990719627994445*^9}},ExpressionUUID->"d9527f64-587d-486b-abca-\
048ebae9d21a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ComplexPlot", "[", 
  RowBox[{
   RowBox[{"JacobiCN", "[", 
    RowBox[{"u", ",", ".8"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"u", ",", "10"}], "}"}]}], "]"}]], "Input",
