Cell["\<\
Translating to complex numbers, we saw above that after one period\
\>", "Text",
 CellChangeTimes->{{3.991235543011016*^9, 
  3.991235569736806*^9}},ExpressionUUID->"c6eafcd7-fa96-447b-9da2-\
0ce2331e6c8e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Omega]", "1"], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{"2", 
      SubscriptBox["\[Omega]", "1"]}], "+", 
     SubscriptBox["\[Omega]", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5a531740-b007-47bf-a672-d8b14572ee32"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Omega]", "2"], "\[RightTeeArrow]", 
    RowBox[{
     SubscriptBox["\[Omega]", "1"], "+", 
     SubscriptBox["\[Omega]", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d645feb1-9898-4797-a0be-3e2d01d4c513"],
 "."
}], "Text",
 CellChangeTimes->{{3.991235574992415*^9, 
  3.991235602698159*^9}},ExpressionUUID->"42c32eb9-09fe-4e8d-867a-\
a93dd26d4e4f"],

Cell["In particular, our zeros and poles get sent as follows:", "Text",
 CellChangeTimes->{{3.991235604766631*^9, 
  3.991235617139289*^9}},ExpressionUUID->"a1a0dcf5-b056-4953-9ada-\
a5f94cb4e7a5"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", 
     FractionBox[
      SubscriptBox["\[Omega]", "1"], "4"]}], "\[RightTeeArrow]", 
    RowBox[{"\[PlusMinus]", 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        SubscriptBox["\[Omega]", "1"], "2"], "+", 
       FractionBox[
        SubscriptBox["\[Omega]", "2"], "4"]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ef40881d-2753-426d-b418-fac42fb98ff1"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{"3", 
         SubscriptBox["\[Omega]", "1"]}], "4"], "+", 
       FractionBox[
        SubscriptBox["\[Omega]", "2"], "2"]}], ")"}]}], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{"\[PlusMinus]", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", 
         SubscriptBox["\[Omega]", "1"]}], "+", 
        FractionBox[
         RowBox[{"5", 
          SubscriptBox["\[Omega]", "2"]}], "4"]}], ")"}]}], "\[Congruent]", 
     RowBox[{
      RowBox[{"\[PlusMinus]", 
       FractionBox[
        SubscriptBox["\[Omega]", "2"], "4"]}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"mod", " ", 
         SubscriptBox["\[Omega]", "1"]}], ",", 
        SubscriptBox["\[Omega]", "2"]}], ")"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "027ba77f-c77f-4cf8-8b33-bcd27bab770e"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", 
     FractionBox[
      SubscriptBox["\[Omega]", "2"], "4"]}], "\[RightTeeArrow]", 
    RowBox[{"\[PlusMinus]", 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        SubscriptBox["\[Omega]", "1"], "4"], "+", 
       FractionBox[
        SubscriptBox["\[Omega]", "2"], "4"]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fa421314-1697-415c-88b3-b9b0118c2068"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        SubscriptBox["\[Omega]", "1"], "2"], "+", 
       FractionBox[
        RowBox[{"3", 
         SubscriptBox["\[Omega]", "2"]}], "4"]}], ")"}]}], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{"\[PlusMinus]", 
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         RowBox[{"7", 
          SubscriptBox["\[Omega]", "1"]}], "4"], "+", 
        FractionBox[
         RowBox[{"5", 
          SubscriptBox["\[Omega]", "2"]}], "4"]}], ")"}]}], "\[Congruent]", 
     RowBox[{
      RowBox[{"\[PlusMinus]", 
       RowBox[{"(", 
        RowBox[{
         FractionBox[
          RowBox[{"3", 
           SubscriptBox["\[Omega]", "1"]}], "4"], "+", 
         FractionBox[
          SubscriptBox["\[Omega]", "2"], "4"]}], ")"}]}], "  ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"mod", " ", 
         SubscriptBox["\[Omega]", "1"]}], ",", 
        SubscriptBox["\[Omega]", "2"]}], ")"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d141e8b5-0d45-4045-8808-7a2e2a5fadc7"]
}], "Text",
 CellChangeTimes->{{3.9912356219900513`*^9, 3.991235885026469*^9}, {
  3.991236062767755*^9, 
  3.991236063932885*^9}},ExpressionUUID->"95e21fa1-6a7b-486c-9987-\
d0359b14e58b"],

Cell[TextData[{
 "Note that, for any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["a", "4"], 
     SubscriptBox["\[Omega]", "1"]}], "+", 
    RowBox[{
     FractionBox["b", "4"], 
     SubscriptBox["\[Omega]", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c1ce0528-ca07-4592-9301-3ec186b94553"],
 ", this dynamical system has period 3:"
}], "Text",
 CellChangeTimes->{{3.9912372675167923`*^9, 
  3.9912373178599873`*^9}},ExpressionUUID->"26a7b157-3f5f-4ba6-91b9-\
8e17b0089e13"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Mod", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"MatrixPower", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"2", ",", "1"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"1", ",", "1"}], "}"}]}], "}"}], ",", "i"}], "]"}], ".", 
        
        RowBox[{"{", 
         RowBox[{
          RowBox[{"a", "/", "4"}], ",", 
          RowBox[{"b", "/", "4"}]}], "}"}]}], ",", "1"}], "]"}], ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", "b"}], "}"}], "\[Element]", "Integers"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"i", ",", "0", ",", "3"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.991236536898614*^9, 3.991236592954368*^9}, {
  3.991236658720495*^9, 3.9912367689271927`*^9}, {3.991237102541955*^9, 
  3.991237106842552*^9}, {3.9912371499870167`*^9, 3.99123715016617*^9}, {
  3.991237180681568*^9, 3.991237180761467*^9}, {3.9912372149671373`*^9, 
  3.991237252513811*^9}, {3.991237321757071*^9, 3.991237329140553*^9}},
 CellLabel->
  "In[422]:=",ExpressionUUID->"66f5ec34-7894-4361-acf9-80ad092d12aa"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mod", "[", 
      RowBox[{
       FractionBox["a", "4"], ",", "1"}], "]"}], ",", 
     RowBox[{"Mod", "[", 
      RowBox[{
       FractionBox["b", "4"], ",", "1"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mod", "[", 
      RowBox[{
       RowBox[{
        FractionBox["1", "4"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", "a"}], "+", "b"}], ")"}]}], ",", "1"}], "]"}], ",", 
     RowBox[{"Mod", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"a", "+", "b"}], "4"], ",", "1"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mod", "[", 
      RowBox[{
       RowBox[{
        FractionBox["1", "4"], " ", 
        RowBox[{"(", 
         RowBox[{"a", "+", 
          RowBox[{"3", " ", "b"}]}], ")"}]}], ",", "1"}], "]"}], ",", 
     RowBox[{"Mod", "[", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{"3", " ", "a"}], "4"], "+", 
        FractionBox["b", "2"]}], ",", "1"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Mod", "[", 
      RowBox[{
       FractionBox["a", "4"], ",", "1"}], "]"}], ",", 
     RowBox[{"Mod", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"5", " ", "b"}], "4"], ",", "1"}], "]"}]}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.9912373241409082`*^9, 3.991237329804058*^9}},
 CellLabel->
  "Out[422]=",ExpressionUUID->"7eb7e366-1671-4486-b782-1874bd6e76af"]
}, Open  ]],

Cell["\<\
So we\[CloseCurlyQuote]ll need to run the modular flow for 3 periods to get a \
looping animation.\
\>", "Text",
 CellChangeTimes->{{3.991237345296895*^9, 
  3.991237376848333*^9}},ExpressionUUID->"6e3393b6-3e74-4e81-8369-\
4709634cd65e"],

Cell[TextData[{
 "The last piece is to use the ",
 StyleBox["vik0", "Input"],
 " cyclic gradient from ",
 ButtonBox["Scientific Color Maps",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.fabiocrameri.ch/colourmaps/"], None},
  ButtonNote->"https://www.fabiocrameri.ch/colourmaps/"],
 ":"
}], "Text",
 CellChangeTimes->{{3.991237380702888*^9, 
  3.991237411113606*^9}},ExpressionUUID->"bd7c33fc-28df-48f2-b75a-\
7f2948469058"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cols", "=", 
   RowBox[{"{", 
    RowBox[{
     TemplateBox[<|
      "color" -> RGBColor[
