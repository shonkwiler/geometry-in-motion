Cell["So here\[CloseCurlyQuote]s the code for the animation:", "Text",
 CellChangeTimes->{{3.991237419092334*^9, 
  3.991237424376129*^9}},ExpressionUUID->"4c08303b-8287-4f0f-8380-\
418da15e1491"],

Cell[BoxData[
 RowBox[{
  RowBox[{"jacobi", "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Omega]1", ",", "\[Omega]2", ",", "g2", ",", "g3", ",", 
       RowBox[{"U", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"GoldenRatio", ",", "1"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", 
            RowBox[{"-", "GoldenRatio"}]}], "}"}]}], "}"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"ParallelTable", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"\[Omega]1", ",", "\[Omega]2"}], "}"}], "=", 
           RowBox[{
            RowBox[{
             RowBox[{"N", "[", 
              RowBox[{"Complex", "@@", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"DiagonalMatrix", "[", 
                  RowBox[{"{", 
                   RowBox[{
                    SuperscriptBox["E", "s"], ",", 
                    SuperscriptBox["E", 
                    RowBox[{"-", "s"}]]}], "}"}], "]"}], ".", "U", ".", "#"}],
                 ")"}]}], "]"}], "&"}], "/@", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"1", ",", "0"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"g2", ",", "g3"}], "}"}], "=", 
           RowBox[{"WeierstrassInvariants", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\[Omega]1", "/", "2"}], ",", 
              RowBox[{"\[Omega]2", "/", "2"}]}], "}"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"ComplexPlot", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"WeierstrassP", "[", 
                RowBox[{"z", ",", 
                 RowBox[{"{", 
                  RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}], "-", 
               RowBox[{"WeierstrassP", "[", 
                RowBox[{
                 RowBox[{"\[Omega]1", "/", "4"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}]}], ")"}], 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"WeierstrassP", "[", 
                 RowBox[{"z", ",", 
                  RowBox[{"{", 
                   RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}], "-", 
                RowBox[{"WeierstrassP", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"3", 
                    RowBox[{"\[Omega]1", "/", "4"}]}], "+", 
                   RowBox[{"\[Omega]2", "/", "2"}]}], ",", 
                  RowBox[{"{", 
                   RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}]}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"WeierstrassP", "[", 
                   RowBox[{"z", ",", 
                    RowBox[{"{", 
                    RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}], "-", 
                  RowBox[{"WeierstrassP", "[", 
                   RowBox[{
                    RowBox[{"\[Omega]2", "/", "4"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}]}], ")"}], 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"WeierstrassP", "[", 
                   RowBox[{"z", ",", 
                    RowBox[{"{", 
                    RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}], "-", 
                  RowBox[{"WeierstrassP", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"3", 
                    RowBox[{"\[Omega]2", "/", "4"}]}], "+", 
                    RowBox[{"\[Omega]1", "/", "2"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}]}], ")"}]}], 
               ")"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"z", ",", "2"}], "}"}], ",", 
            RowBox[{"ColorFunction", "\[Rule]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"Blend", "[", 
                 RowBox[{"cols", ",", 
                  RowBox[{"Mod", "[", 
                   RowBox[{"#8", ",", "1"}], "]"}]}], "]"}], "&"}], ",", 
               "None"}], "}"}]}], ",", 
            RowBox[{"Frame", "->", "False"}], ",", 
            RowBox[{"PlotRangePadding", "\[Rule]", "None"}], ",", 
            RowBox[{"ImagePadding", "->", "None"}], ",", 
            RowBox[{"BoundaryStyle", "->", "None"}], ",", 
            RowBox[{"ImageSize", "->", "270"}], ",", 
            RowBox[{"Exclusions", "->", "None"}]}], "]"}]}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"s", ",", "0.", ",", 
           RowBox[{
            RowBox[{"3", 
             RowBox[{"Log", "[", 
              RowBox[{"1", "+", "GoldenRatio"}], "]"}]}], "-", "#"}], ",", 
           "#"}], "}"}]}], "]"}], "&"}], "[", 
      RowBox[{
       RowBox[{"Log", "[", 
        RowBox[{"1", "+", "GoldenRatio"}], "]"}], "/", "50."}], "]"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9811293781299686`*^9, 3.98112942067301*^9}, {
   3.981129456950342*^9, 3.9811294574136953`*^9}, {3.9811295837602882`*^9, 
   3.9811295894052563`*^9}, {3.9907205051108828`*^9, 
   3.9907205051640368`*^9}, {3.990720536176529*^9, 3.990720539750593*^9}, {
   3.9907205849407*^9, 3.990720587560464*^9}, {3.990720774842729*^9, 
   3.9907207749706497`*^9}, {3.9907224781620626`*^9, 
   3.9907224782434587`*^9}, {3.991225607809739*^9, 3.9912256329271717`*^9}, {
   3.991225991156096*^9, 3.991226021042014*^9}, {3.991226171998506*^9, 
   3.9912261778493958`*^9}, 3.991226359562986*^9, {3.991237555341913*^9, 
   3.9912375554234123`*^9}, {3.99123897338384*^9, 
   3.991238976449502*^9}},ExpressionUUID->"d07b6848-fc88-4a73-b568-\
cb73db837ad5"],

Cell["Which we can export to a GIF:", "Text",
