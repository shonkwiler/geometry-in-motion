Notebook[{

Cell[CellGroupData[{
Cell["cn", "Title",
 CellChangeTimes->{{3.990718522117219*^9, 
  3.990718522223588*^9}},ExpressionUUID->"7a891056-afd8-4f62-9ca8-\
c393203412b6"],

Cell["\[LongDash] Clayton Shonkwiler, June 2026", "Text",
 CellChangeTimes->{{3.990718541607411*^9, 
  3.990718546887494*^9}},ExpressionUUID->"6c8b1c66-a071-4c65-aef1-\
50c2b50f2d9a"],

Cell[TextData[{
 "This animation uses the ",
 ButtonBox["modular flow",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://community.wolfram.com/groups/-/m/t/3061781"], None},
  ButtonNote->"https://community.wolfram.com/groups/-/m/t/3061781"],
 " to produce a periodic family of ",
 ButtonBox["Jacobi elliptic functions",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Jacobi_elliptic_functions"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Jacobi_elliptic_functions"],
 " of type cn, visualized using ",
 ButtonBox["domain coloring",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1080/10511970.2016.1234526"], None},
  ButtonNote->"https://doi.org/10.1080/10511970.2016.1234526"],
 ". This is also explained in my paper ",
 ButtonBox["\[OpenCurlyDoubleQuote]Looping animations using the modular flow \
and elliptic functions,\[CloseCurlyDoubleQuote]",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://archive.bridgesmathart.org/2026/bridges2026-533.html"], None},
  ButtonNote->
   "https://archive.bridgesmathart.org/2026/bridges2026-533.html"],
 " which has just been published in ",
 StyleBox[ButtonBox["Proceedings of Bridges 2026",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://archive.bridgesmathart.org/2026"], None},
  ButtonNote->"https://archive.bridgesmathart.org/2026"],
  FontSlant->"Italic"],
 ".",
 " "
}], "Text",
 CellChangeTimes->{{3.990546745649385*^9, 3.990546772968005*^9}, {
   3.990546822257875*^9, 3.990546875825235*^9}, {3.990546958658849*^9, 
   3.990546958659156*^9}, {3.990546998905801*^9, 3.990547062103488*^9}, {
   3.990718563182681*^9, 3.9907186077477427`*^9}, {3.991239099104355*^9, 
   3.9912391768096313`*^9}, {3.991239208152046*^9, 3.991239224987132*^9}, 
   3.9913079134908447`*^9},ExpressionUUID->"e6f804dc-6d77-4bdf-a29e-\
fa04527487cb"],

Cell[CellGroupData[{

Cell["The Modular Flow", "Section",
 CellChangeTimes->{{3.990718618145294*^9, 
  3.990718620846389*^9}},ExpressionUUID->"3c368247-fa37-47f8-8cdb-\
ce58be6f07af"],

Cell[TextData[{
 "See ",
 StyleBox[ButtonBox["Quasi",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://community.wolfram.com/groups/-/m/t/3734174"], None},
  ButtonNote->"https://community.wolfram.com/groups/-/m/t/3734174"],
  FontSlant->"Italic"],
 " or the paper for an explanation of the modular flow. The upshot is that \
when ",
 Cell[BoxData[
  FormBox["\[CapitalLambda]", TraditionalForm]],ExpressionUUID->
  "8c617248-96b5-4ee4-b99a-486fc566f327"],
 " is the planar lattice generated by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["u", "\[RightVector]"], "1"], "=", 
    RowBox[{"(", GridBox[{
       {"\[Phi]"},
       {"1"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "84bee8ca-9d1b-4165-92ac-bcf86b613133"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["u", "\[RightVector]"], "2"], "=", 
    RowBox[{"(", GridBox[{
       {"1"},
       {
        RowBox[{"-", "\[Phi]"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "b88931cc-3d6b-43c0-8cac-a7c43daf4876"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "=", 
    FractionBox[
     RowBox[{"1", "+", 
      SqrtBox["5"]}], "2"]}], TraditionalForm]],ExpressionUUID->
  "de49ac75-09c4-4aa8-9c87-ba889c3d1f59"],
 " is the golden ratio), and we act on the lattice points by the family of \
matrices ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       SuperscriptBox["\[ExponentialE]", "t"], "0"},
      {"0", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", "t"}]]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "6f865bc1-904d-42e0-8aff-47317bdbca40"],
 " to get the family ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[CenterDot]", "\[CapitalLambda]"}], TraditionalForm]],
  ExpressionUUID->"3bfe12a0-ed7a-490c-8cfe-b4d08fe25d86"],
 " of lattices, this family turns out to be periodic with period ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", "0"], "=", 
    RowBox[{"ln", "(", 
     RowBox[{"1", "+", "\[Phi]"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "f6cc8386-1d62-433c-89c4-a65361c3f7de"],
 ":"
}], "Text",
 CellChangeTimes->{{3.990718623646325*^9, 3.990718811495103*^9}, {
  3.990720065030188*^9, 3.990720089996998*^9}, {3.990720162468746*^9, 
  3.990720164282782*^9}, {3.990722572692561*^9, 3.990722580160521*^9}, {
  3.991234961040412*^9, 3.991234963175248*^9}, {3.9912403728252153`*^9, 
  3.9912403728262787`*^9}},ExpressionUUID->"9f9580b9-249c-427f-80e7-\
db668f6cdf93"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DynamicModule", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"M", ",", "pts", ",", 
     RowBox[{"U", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"GoldenRatio", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "GoldenRatio"}], "}"}]}], "}"}]}]}], "}"}],
    ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pts", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"-", "15"}], ",", "15"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", 
           RowBox[{"-", "15"}], ",", "15"}], "}"}]}], "]"}], ",", "1"}], 
      "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Animate", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "=", 
        RowBox[{
         RowBox[{"DiagonalMatrix", "[", 
          RowBox[{"{", 
           RowBox[{
            SuperscriptBox["E", "s"], ",", 
            SuperscriptBox["E", 
             RowBox[{"-", "s"}]]}], "}"}], "]"}], ".", "U"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Graphics", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Thickness", "[", ".005", "]"}], ",", 
           RowBox[{"PointSize", "[", "Large", "]"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"Point", "[", 
              RowBox[{"M", ".", "#"}], "]"}], "&"}], "/@", "pts"}]}], "}"}], ",", 
         RowBox[{"PlotRange", "->", "10"}]}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"s", ",", "0", ",", 
        RowBox[{"Log", "[", 
         RowBox[{"1", "+", "GoldenRatio"}], "]"}]}], "}"}], ",", 
      RowBox[{"SaveDefinitions", "->", "True"}], ",", 
      RowBox[{"AnimationRunning", "->", "False"}]}], "]"}]}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{
  3.956848782897924*^9, {3.979835617139578*^9, 3.979835678295701*^9}, {
