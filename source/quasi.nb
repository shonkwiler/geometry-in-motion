Notebook[{

Cell[CellGroupData[{
Cell["Quasi", "Title",
 CellChangeTimes->{{3.990546682217142*^9, 3.990546685678803*^9}, 
   3.9905519528498993`*^9},ExpressionUUID->"ed7eada1-353b-4e8e-b452-\
7d038941b333"],

Cell[TextData[{
 "\[LongDash] ",
 ButtonBox["Clayton Shonkwiler",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://shonkwiler.org"], None},
  ButtonNote->"https://shonkwiler.org"],
 ", June 2026"
}], "Text",
 CellChangeTimes->{{3.9905466911747637`*^9, 
  3.990546725634924*^9}},ExpressionUUID->"520e651a-4f22-44a1-96e4-\
d8ddf60a224e"],

Cell[TextData[{
 "This animation uses the ",
 ButtonBox["modular flow",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://community.wolfram.com/groups/-/m/t/3061781"], None},
  ButtonNote->"https://community.wolfram.com/groups/-/m/t/3061781"],
 " to produce a periodic family of quasi-periodic functions. Since the family \
is periodic, we get a looping animation by visualizing with ",
 ButtonBox["domain coloring",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1080/10511970.2016.1234526"], None},
  ButtonNote->"https://doi.org/10.1080/10511970.2016.1234526"],
 ". This is also explained in my paper ",
 ButtonBox["\"Looping animations using the modular flow and elliptic \
functions.\"",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/2603.02088"], None},
  ButtonNote->"https://arxiv.org/abs/2603.02088"]
}], "Text",
 CellChangeTimes->{{3.990546745649385*^9, 3.990546772968005*^9}, {
  3.990546822257875*^9, 3.990546875825235*^9}, {3.990546958658849*^9, 
  3.990546958659156*^9}, {3.990546998905801*^9, 
  3.990547062103488*^9}},ExpressionUUID->"47074639-6056-42fd-a70e-\
55706095f0b3"],

Cell[CellGroupData[{

Cell["The Modular Flow", "Section",
 CellChangeTimes->{{3.990549249492519*^9, 
  3.990549251872665*^9}},ExpressionUUID->"33ced09d-0148-4f27-b950-\
8fd5001a5305"],

Cell[TextData[{
 "See the links which include the phrase \[OpenCurlyDoubleQuote]modular flow\
\[CloseCurlyDoubleQuote] in the previous paragraph for more, but for the \
modular flow the idea is that we will let ",
 Cell[BoxData[
  FormBox["\[DoubleStruckCapitalR]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "252b6218-a138-4e05-8ecb-e779f5519c6f"],
 " act on ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0af0042d-db62-473b-8e16-7b64cb611b08"],
 " by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"t", "\[CenterDot]", 
     RowBox[{"(", 
      RowBox[{"x", ",", "y"}], ")"}]}], " ", ":=", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[ExponentialE]", "t"], "x"}], ",", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", "t"}]], "y"}]}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8fb72309-fdfc-4497-9e6b-2d950bb8d2f9"],
 ". As an action on the plane, this is very far from being periodic, but we \
can also think of the induced action on lattices ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalLambda]", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"m", " ", 
        SubscriptBox[
         OverscriptBox["u", "\[RightVector]"], "1"]}], "+", 
       RowBox[{"n", " ", 
        RowBox[{
         SubscriptBox[
          OverscriptBox["u", "\[RightVector]"], "2"], ":", " ", "m"}]}]}], ",", 
      RowBox[{"n", "\[Element]", "\[DoubleStruckCapitalZ]"}]}], "}"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f24e8c93-c597-42ec-a295-4781605802f7"],
 ", and if we choose ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["u", "\[RightVector]"], "1"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0652231d-66f4-4f1e-bbc7-e26a14b1e08f"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["u", "\[RightVector]"], "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2b49bd3a-46c1-40f9-981e-9e6f4d7c527b"],
 " carefully, the resulting orbit ",
 StyleBox["will",
  FontSlant->"Italic"],
 " be periodic; that is, there will exist ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", "0"], "!=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "49c5186e-f551-469b-b93c-a0331a06914f"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["t", "0"], "\[CenterDot]", "\[CapitalLambda]"}], "=", 
    "\[CapitalLambda]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a669971c-95b6-4f8d-857b-b546e09eba8f"],
 ". "
}], "Text",
 CellChangeTimes->{{3.990547111922385*^9, 3.9905471772164373`*^9}, {
  3.990547225027011*^9, 3.9905473145200233`*^9}, {3.990547364913312*^9, 
  3.990547544040784*^9}, {3.990547605454769*^9, 3.990547703138185*^9}, {
  3.9905478615982733`*^9, 3.99054789302112*^9}, {3.990549554153038*^9, 
  3.990549556822748*^9}, {3.990550278624407*^9, 
  3.990550285106476*^9}},ExpressionUUID->"b3cc83f9-b649-43c6-8e63-\
fed448acbdba"],

Cell[TextData[{
 "To figure out some ",
 Cell[BoxData[
  FormBox["\[CapitalLambda]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d5334218-410b-42de-8414-bc1f77d7d551"],
 " for which this works, let\[CloseCurlyQuote]s turn this into a matrix \
problem. Let ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "decd5b41-128b-4b2f-a20c-9bf0c7d94229"],
 " be the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Cross]", "2"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bbfc085b-c836-4535-be59-650e47f9c390"],
 " matrix with columns ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["u", "\[RightVector]"], "1"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d4eee40a-2bf0-4e71-8031-4765f50968b7"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["u", "\[RightVector]"], "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "98f72183-38a2-4802-baea-ddd071b699cd"],
 ". Then the lattice ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[CenterDot]", "\[CapitalLambda]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "94b761c0-0624-4f38-b0f7-11908212f5ec"],
 " will be generated by the columns of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", GridBox[{
       {
        SuperscriptBox["\[ExponentialE]", "t"], "0"},
       {"0", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"-", "t"}]]}
      }], ")"}], "U"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "73811d9d-c07c-4585-abcb-97e1a49d4ac9"],
 ". On the other hand, if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{"(", GridBox[{
       {"a", "b"},
       {"c", "d"}
      }], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "de65744b-a40b-4f8b-9ad9-91ec4108e840"],
 " is an integer matrix, then the columns of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", " ", "B"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "407165a0-4fef-4172-9311-1c997e279b27"],
 " will be integer linear combinations of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["u", "\[RightVector]"], "1"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "75adfeed-8eba-4402-926a-866d42fd0ede"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["u", "\[RightVector]"], "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c3b8dd43-a1b4-4aca-b6b8-f78096cf418e"],
 "; that is, elements of ",
 Cell[BoxData[
  FormBox["\[CapitalLambda]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8f4a2202-ed32-4447-9965-3d34d5a3b8b8"],
 ". So we might hope that the columns of  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", GridBox[{
       {
        SuperscriptBox["\[ExponentialE]", "t"], "0"},
       {"0", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"-", "t"}]]}
      }], ")"}], "U"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ba2a3411-a0ef-4bb2-8ce9-d758fbb7aca8"],
 " will be the columns of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", " ", "B"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "881fedda-b401-4440-adea-28a40a977e68"],
 ". Moreover, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"det", " ", 
     RowBox[{"(", GridBox[{
        {
         SuperscriptBox["\[ExponentialE]", "t"], "0"},
        {"0", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"-", "t"}]]}
       }], ")"}]}], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6cbe86c6-3458-4c79-a664-c52df18a52a5"],
 ", so the action on ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5fe80dc8-4e40-450c-b28f-d4207223b3f3"],
 " is area-preserving, and we can only hope for this to work if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"det", " ", "B"}], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6fc0c829-fe41-4abf-8da2-7e8aa612a4cf"],
 " as well. "
}], "Text",
 CellChangeTimes->{{3.990547761320891*^9, 3.9905478483357973`*^9}, {
  3.990547899600092*^9, 3.990548081386146*^9}, {3.990548168236864*^9, 
  3.990548248291184*^9}, {3.990548286628931*^9, 
  3.9905483826389837`*^9}},ExpressionUUID->"aff0cea4-9aef-4db4-88f2-\
04c8fcbe8d7c"],

Cell[TextData[{
 "In other words, if we\[CloseCurlyQuote]re looking for a periodic lattice, \
we can try to solve the equation\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", "B"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {
         SuperscriptBox["\[ExponentialE]", 
          SubscriptBox["t", "0"]], "0"},
        {"0", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"-", 
           SubscriptBox["t", "0"]}]]}
       }], ")"}], "U"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "37bdb8e4-6a0c-4981-b814-2a3dc2d5b227"],
 "\n\t\nfor ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0229e55f-d810-463d-b616-bbbd2d3bb66a"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "96e75ab9-b50c-444d-963c-8694ba69643c"],
 ", where ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bf207556-cb3e-411d-9267-693f51379280"],
 " is our favorite ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Cross]", "2"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8f74d69d-4a94-42b7-9c67-ab7936550b70"],
 " matrix with determinant 1."
}], "Text",
 CellChangeTimes->{{3.9905483846471767`*^9, 3.990548441599031*^9}, {
  3.99054850550283*^9, 
  3.99054851290014*^9}},ExpressionUUID->"68788152-b70f-4339-af47-\
0091523e3df3"],

Cell[TextData[{
 "Taking the transpose of both sides, we see that the rows of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "961a51b9-b182-464c-b461-15bf638e0f02"],
 " must be eigenvectors of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["B", "T"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b25522e3-754b-49b4-beb7-d97ff8a2b841"],
 " with corresponding eigenvalues ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[PlusMinus]", 
     SubscriptBox["t", "0"]}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "32938181-006e-46bb-ae67-16056991799d"],
 ". So for example when ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{"(", GridBox[{
       {"2", "1"},
       {"1", "1"}
      }], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dd744594-9c97-4bcc-8063-813f6714d488"],
 " we have:"
}], "Text",
 CellChangeTimes->{{3.9905484591896057`*^9, 3.990548594310554*^9}, 
   3.990548643400305*^9},ExpressionUUID->"5c6f177b-7b8e-4067-89bc-\
fccf66826242"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Eigensystem", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"2", ",", "1"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "1"}], "}"}]}], "}"}], "]"}]], "Input",
 CellChangeTimes->{{3.990548595685738*^9, 3.990548609748638*^9}},
 CellLabel->
  "In[392]:=",ExpressionUUID->"1303d8d0-b9f5-4b1b-8369-a1eb17a600b7"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], " ", 
      RowBox[{"(", 
       RowBox[{"3", "+", 
        SqrtBox["5"]}], ")"}]}], ",", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      RowBox[{"(", 
       RowBox[{"3", "-", 
        SqrtBox["5"]}], ")"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        FractionBox["1", "2"], " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SqrtBox["5"]}], ")"}]}], ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        FractionBox["1", "2"], " ", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SqrtBox["5"]}], ")"}]}], ",", "1"}], "}"}]}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.990548601515892*^9, 3.990548610565073*^9}},
 CellLabel->
  "Out[392]=",ExpressionUUID->"95c46213-e0e4-4288-acf2-c17e9dfdd04a"]
}, Open  ]],

Cell[TextData[{
 "That is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["u", "\[RightVector]"], "1"], "=", 
    RowBox[{"(", GridBox[{
       {"\[Phi]"},
       {"1"}
      }], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "859fa4a9-3fe0-4feb-92a8-f2ba7d3dbc92"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["u", "\[RightVector]"], "2"], "=", 
    RowBox[{"(", GridBox[{
       {
        RowBox[{
         RowBox[{"-", "1"}], "/", "\[Phi]"}]},
       {"1"}
      }], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f997814b-433f-4010-a04d-2d1c3fdbfab9"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", "0"], "=", 
    RowBox[{"ln", "(", 
     RowBox[{"1", "+", "\[Phi]"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3ec0a713-2f92-4133-961d-e8eeb879dae1"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "=", 
    FractionBox[
     RowBox[{"1", "+", 
      SqrtBox["5"]}], "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "989ad3a2-a035-4018-b30c-0af79b533c20"],
 " is the golden ratio. In fact, I could just as well scale ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["u", "\[RightVector]"], "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c4848bbe-5a28-4512-b478-c77d2e282ca6"],
 " by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "\[Phi]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "745b7ae5-0ad3-419b-b6f9-60d21728fbd4"],
 " to get the more pleasing ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{"(", GridBox[{
       {"\[Phi]", "1"},
       {"1", 
        RowBox[{"-", "\[Phi]"}]}
      }], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7eaee323-bbac-4fc2-a714-b974524095ff"],
 ". Let\[CloseCurlyQuote]s visualize this and see that it really is \
periodic:"
}], "Text",
 CellChangeTimes->{{3.990548645430574*^9, 3.990548678427487*^9}, {
  3.99054874538725*^9, 3.990548849972952*^9}, {3.990548996938946*^9, 
  3.990549011171445*^9}},ExpressionUUID->"1144b3c0-6b7d-4e9a-a593-\
b33e5160f57f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DynamicModule", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"M", ",", "pts", ",", 
     RowBox[{"U", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"GoldenRatio", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "GoldenRatio"}], "}"}]}], "}"}]}]}], "}"}],
    ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pts", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"-", "15"}], ",", "15"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", 
           RowBox[{"-", "15"}], ",", "15"}], "}"}]}], "]"}], ",", "1"}], 
      "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Animate", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "=", 
        RowBox[{
         RowBox[{"DiagonalMatrix", "[", 
          RowBox[{"{", 
           RowBox[{
            SuperscriptBox["E", "s"], ",", 
            SuperscriptBox["E", 
             RowBox[{"-", "s"}]]}], "}"}], "]"}], ".", "U"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Graphics", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Thickness", "[", ".005", "]"}], ",", 
           RowBox[{"PointSize", "[", "Large", "]"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"Point", "[", 
              RowBox[{"M", ".", "#"}], "]"}], "&"}], "/@", "pts"}]}], "}"}], ",", 
         RowBox[{"PlotRange", "->", "10"}]}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"s", ",", "0", ",", 
        RowBox[{"Log", "[", 
         RowBox[{"1", "+", "GoldenRatio"}], "]"}]}], "}"}], ",", 
      RowBox[{"SaveDefinitions", "->", "True"}], ",", 
      RowBox[{"AnimationRunning", "->", "False"}]}], "]"}]}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{
  3.956848782897924*^9, {3.979835617139578*^9, 3.979835678295701*^9}, {
   3.979835758851214*^9, 3.979835785608203*^9}, {3.979835843088931*^9, 
   3.9798358709263353`*^9}, {3.979835916414978*^9, 3.979835939133374*^9}, {
   3.979835970168416*^9, 3.979835993949575*^9}, {3.979836157375984*^9, 
   3.979836219378332*^9}, {3.9798362748172703`*^9, 3.979836277314559*^9}, {
   3.9798363600541067`*^9, 3.979836370170804*^9}, {3.979917669398548*^9, 
   3.979917711400195*^9}, {3.9799177493903017`*^9, 3.979917752023755*^9}, {
   3.979917866033456*^9, 3.979917881988151*^9}, {3.9799181154926243`*^9, 
