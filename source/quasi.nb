Cell[CellGroupData[{

Cell["A Quasiperiodic Function ", "Section",
 CellChangeTimes->{{3.990549263768696*^9, 
  3.990549273755018*^9}},ExpressionUUID->"9be80186-cdd8-4c51-b602-\
73b3a1cfabb5"],

Cell[TextData[{
 "Now, think of the lattice ",
 Cell[BoxData[
  FormBox["\[CapitalLambda]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "aeed5a58-abaf-42c6-97c7-063606055e5c"],
 " as living in ",
 Cell[BoxData[
  FormBox["\[DoubleStruckCapitalC]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9dae5091-6d7b-4421-824e-118a5d12f2d8"],
 " rather than in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b260ddec-a4be-4594-bddb-8b8b158183fb"],
 ". That is, we now think of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalLambda]", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", "1"], 
        SubscriptBox["\[Omega]", "1"]}], "+", 
       RowBox[{
        SubscriptBox["a", "2"], 
        RowBox[{
         SubscriptBox["\[Omega]", "2"], ":", 
         SubscriptBox["a", "1"]}]}]}], ",", 
      RowBox[{
       SubscriptBox["a", "2"], "\[Element]", "\[DoubleStruckCapitalZ]"}]}], 
     "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "568bde6b-f054-4f18-8460-d38f21a3d0fa"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Omega]", "1"], ",", 
    RowBox[{
     SubscriptBox["\[Omega]", "2"], "\[Element]", 
     "\[DoubleStruckCapitalC]"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "262ca173-a9b8-4606-8c41-d5bdf8c91b1d"],
 ". And, for any such lattice we can think about doubly-periodic functions \
with periods ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "1"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f3c740b3-12b5-4f79-b96b-cdc516f6d387"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Omega]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "00b79360-e767-43fb-82b2-b8b65c161adc"],
 "; that is, functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", ":", "\[DoubleStruckCapitalC]"}], "\[Rule]", 
    "\[DoubleStruckCapitalC]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "00500832-719b-49d7-a8a6-1d28b6f6734e"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", 
     RowBox[{"z", "+", 
      SubscriptBox["\[Omega]", "1"]}], ")"}], "=", 
    RowBox[{
     RowBox[{"f", "(", "z", ")"}], "=", 
     RowBox[{"f", "(", 
      RowBox[{"z", "+", 
       SubscriptBox["\[Omega]", "2"]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "93f096f2-016b-458c-af93-99b3242f2f65"],
 ", which of course implies ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", 
     RowBox[{"z", "+", 
      RowBox[{"m", " ", 
       SubscriptBox["\[Omega]", "1"]}], "+", 
      RowBox[{"n", " ", 
       SubscriptBox["\[Omega]", "2"]}]}], ")"}], "=", 
    RowBox[{"f", "(", "z", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "875ba4d5-fa99-416d-8d4d-eebe4e5faad8"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", ",", 
    RowBox[{"n", "\[Element]", "\[DoubleStruckCapitalZ]"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "44bacbe9-b6dd-4276-b4d2-a99503d033d3"],
 ". If such an ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0604d314-30bc-4dab-8c3d-6fc26dd1dff2"],
 " is ",
 ButtonBox["meromorphic",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Meromorphic_function"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Meromorphic_function"],
 " then it is usually called an ",
 StyleBox[ButtonBox["elliptic function",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Elliptic_function"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Elliptic_function"],
  FontSlant->"Italic"],
 "."
}], "Text",
 CellChangeTimes->{{3.990549296921179*^9, 3.990549699425445*^9}, {
   3.9905497458844233`*^9, 3.990549770902073*^9}, {3.9905498064669657`*^9, 
   3.99054987837115*^9}, 3.9905499327979517`*^9, {3.9905502953732433`*^9, 
   3.990550337659327*^9}},ExpressionUUID->"a9056ced-fe70-427e-899d-\
dda228382f2f"],

Cell[TextData[{
 "This is the idea behind the animation ",
 StyleBox[ButtonBox["Phase",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://community.wolfram.com/groups/-/m/t/3465926"], None},
  ButtonNote->"https://community.wolfram.com/groups/-/m/t/3465926"],
  FontSlant->"Italic"],
 ", where I applied this idea to the most basic elliptic function, the \
Weierstrass ",
 Cell[BoxData[
  FormBox["\[WeierstrassP]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "63a6a616-74b3-4428-a02c-7144fceae8ef"],
 "-function. Since this function depends on the lattice ",
 Cell[BoxData[
  FormBox["\[CapitalLambda]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cd48fb39-e0cb-4cf0-9613-c4afd5a435a4"],
 ", I like to write it as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[WeierstrassP]", "\[CapitalLambda]"], "(", "z", ")"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b818e114-79aa-4871-bc00-44e278333842"],
 ", though it\[CloseCurlyQuote]s more common to write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[WeierstrassP]", "(", 
    RowBox[{"p", ",", 
     SubscriptBox["\[Omega]", "1"], ",", 
     SubscriptBox["\[Omega]", "2"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b0697e1c-3e55-4be6-bcef-41954041f34a"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[WeierstrassP]", "(", 
    RowBox[{
     RowBox[{"z", ";", 
      SubscriptBox["g", "2"]}], ",", 
     SubscriptBox["g", "3"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6d529357-0c83-4e5c-b7cc-4bbc007a51b1"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "2"], ",", 
    SubscriptBox["g", "3"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9b70eec6-cf6a-45a0-925a-aeaea45d7f1b"],
 " are the Weierstrass invariants of ",
 Cell[BoxData[
  FormBox["\[CapitalLambda]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e2a1b500-69c5-43bb-8368-71fd5c963ef1"],
 ", and indeed this latter is how Mathematica works. In the below code, I \
translate back and forth between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Omega]", "1"], ",", 
     SubscriptBox["\[Omega]", "2"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "662d3352-9569-4dc4-b5c4-2cece56039e6"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["g", "2"], ",", 
     SubscriptBox["g", "3"]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2fcbe28a-3cf3-484c-913a-ea60ea793d09"],
 " using the built-in Mathematica function ",
 StyleBox["WeierstrassInvariants", "Input"],
 "."
}], "Text",
 CellChangeTimes->{{3.990549935157757*^9, 3.990549986855836*^9}, {
  3.990550091684615*^9, 3.9905501072447977`*^9}, {3.9905505218728*^9, 
  3.99055060925394*^9}},ExpressionUUID->"02147255-c4d0-4831-9ccf-\
ff1edeac0229"],

Cell[TextData[{
 "In any case, the point is that if we have a periodic family ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[CenterDot]", "\[CapitalLambda]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b2de986f-c2b5-4df7-92d0-448b5e56463c"],
 " of lattices, then the corresponding family ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[WeierstrassP]", 
    RowBox[{"t", "\[CenterDot]", "\[CapitalLambda]"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "04f3691a-c4b6-4f39-b563-e7626f66a65b"],
 " is also periodic (and likewise for any other elliptic function), and so \
produces a looping animation when visualized."
}], "Text",
 CellChangeTimes->{{3.990550523875218*^9, 3.990550533316758*^9}, {
  3.9905506354191513`*^9, 
  3.990550643092682*^9}},ExpressionUUID->"b8af48df-6b94-42f9-bab1-\
2d3fcdcdf41e"],

Cell[TextData[{
 "Here I\[CloseCurlyQuote]m going to apply the same idea to a ",
 StyleBox["quasiperiodic",
  FontSlant->"Italic"],
 " function, namely the ",
 ButtonBox["Weierstrass ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Weierstrass_functions"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Weierstrass_functions"],
 Cell[BoxData[
  FormBox[
   ButtonBox[
    SubscriptBox["\[Sigma]", "\[CapitalLambda]"],
    BaseStyle->"Hyperlink",
    ButtonData->{
      URL["https://en.wikipedia.org/wiki/Weierstrass_functions"], None},
    ButtonNote->"https://en.wikipedia.org/wiki/Weierstrass_functions"], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "35e259f2-2120-40c3-bc56-40cf9d08cf91"],
 ButtonBox[" function",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Weierstrass_functions"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Weierstrass_functions"],
 ", which is implicitly defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox[
      SuperscriptBox["d", "2"], 
      RowBox[{"d", " ", 
       SuperscriptBox["z", "2"]}]], 
     RowBox[{"ln", "(", 
      SubscriptBox["\[Sigma]", "\[CapitalLambda]"], ")"}]}], "=", 
    RowBox[{"-", 
     SubscriptBox["\[WeierstrassP]", "\[CapitalLambda]"]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3a13e984-3153-4d30-8774-afe3ec8e15f4"],
 ". This function is entire and can be used to represent all elliptic \
functions by way of their zeros and poles. Plus, it looks weird and \
interesting:"
}], "Text",
 CellChangeTimes->{{3.990549908442775*^9, 3.990549913765665*^9}, {
  3.990549992635996*^9, 3.9905500568009872`*^9}, {3.990550180637588*^9, 
  3.990550180659894*^9}, {3.9905506503977623`*^9, 3.9905506936283493`*^9}, {
  3.9905507267315702`*^9, 3.990550759907856*^9}, {3.9905508711426973`*^9, 
  3.990550897058381*^9}},ExpressionUUID->"b3f81a65-54f5-4795-beb6-\
a6aa528f4a8b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ComplexPlot", "[", 
  RowBox[{
   RowBox[{"WeierstrassSigma", "[", 
    RowBox[{"z", ",", 
     RowBox[{"WeierstrassInvariants", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", "I"}], "}"}], "]"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"z", ",", "10"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.990550898197796*^9, 3.990550907741922*^9}, {
  3.990550946302314*^9, 3.990550967621522*^9}},
 CellLabel->
  "In[411]:=",ExpressionUUID->"c2365b1e-6a29-49ce-883f-66756d76f6db"],

