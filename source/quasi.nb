Cell[TextData[{
 "Putting it all together, we\[CloseCurlyQuote]re going to let ",
 Cell[BoxData[
  FormBox["\[CapitalLambda]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7c734dcb-b0dc-4272-a939-bbe4834da51d"],
 " be the lattice generated by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {"\[Phi]"},
      {"1"}
     }], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fa4717b6-b697-4fce-ad2d-a8bfec341b4a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {"1"},
      {
       RowBox[{"-", "\[Phi]"}]}
     }], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "91dd4e6d-5725-4750-99dd-7377552a7da0"],
 " (or, in complex terms, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "+", "\[ImaginaryI]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c21729b2-46c5-433b-bfe7-6f30d5878f95"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "43d1eaf3-d3cb-48be-863f-b2fe21a6bccb"],
 "), we\[CloseCurlyQuote]re going to let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[CenterDot]", "\[CapitalLambda]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dfb37648-1477-444b-8f75-67aae70db118"],
 " be its periodic orbit under the modular flow (with period ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", "0"], "=", 
    RowBox[{"ln", "(", 
     RowBox[{"1", "+", "\[Phi]"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "eef002fa-9141-42bc-a15a-09014f1c4aba"],
 "), and we\[CloseCurlyQuote]re going to build the corresponding periodic \
family of quasiperiodic functions ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", 
    RowBox[{"t", "\[CenterDot]", "\[CapitalLambda]"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0b7dc393-5914-49a4-a55e-622c969e3523"],
 ", which we\[CloseCurlyQuote]ll visualize and turn into a looping animation \
using domain coloring. "
}], "Text",
 CellChangeTimes->{{3.990550996190432*^9, 
  3.990551153314146*^9}},ExpressionUUID->"b9423c85-8aff-456a-81d1-\
232557d8b64e"],

Cell[TextData[{
 "For this, I\[CloseCurlyQuote]m using the ",
 StyleBox["vik0", "Input"],
 " cyclic gradient from ",
 ButtonBox["Scientific Color Maps",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.fabiocrameri.ch/colourmaps/"], None},
  ButtonNote->"https://www.fabiocrameri.ch/colourmaps/"],
 ":"
}], "Text",
 CellChangeTimes->{{3.990546502445169*^9, 3.990546529300948*^9}, {
  3.990551161295656*^9, 
  3.990551164809195*^9}},ExpressionUUID->"24933101-96ff-4958-a0f8-\
929e0a7c0b90"],

